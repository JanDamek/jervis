
# Build artifacts
build/
# Keep generated Protobuf/gRPC stubs committed per docs/inter-service-contracts.md §10.
!shared/service-contracts/build/
shared/service-contracts/build/*
!shared/service-contracts/build/generated/
shared/service-contracts/build/generated/*
!shared/service-contracts/build/generated/source/
shared/service-contracts/build/generated/source/*
!shared/service-contracts/build/generated/source/buf/
.gradle/
.kotlin/
jervis backup/

# Xcode user data
*.xcuserstate
xcuserdata/

# Python
__pycache__/
*.pyc
*.egg-info/
data/
backend/service-knowledgebase/scripts/

# uv workspace — keep uv.lock committed for reproducibility, ignore venv
.venv/
.python-version

# IntelliJ — .run/ holds shared run/debug configurations (committed).
# User's global ~/.gitignore_global ignores .run by default; re-include it
# here so the repo can ship reproducible run configs for the team.
!.run/
!.run/**
